//Put the block lookup tables between these. This way we don't have to marshal the data between the CPU and GPU.
// BLOCK_LOOKUP_TABLES_START

// BLOCK_LOOKUP_TABLES_END

// --- Helper Functions ---

// The fade function, which is a 5th-degree polynomial: 6t^5 - 15t^4 + 10t^3
// This creates a smoother interpolation than linear.
float mcn_fade(float t) {
    return t * t * t * (t * (t * 6.0 - 15.0) + 10.0);
}

// Linear interpolation
float mcn_lerp(float t, float a, float b) {
    return a + t * (b - a);
}

// Gradient function. Selects a 3D gradient vector from a pre-defined set
// based on the hash value.
float3 mcn_grad(int hash, float3 p) {
    int h = hash & 15;
    // In Java, this was done with a switch statement.
    // Here, we use direct selection based on the hash.
    float u = h < 8 ? p.x : p.y;
    float v = h < 4 ? p.y : (h == 12 || h == 14 ? p.x : p.z);
    return ((h & 1) == 0 ? u : -u) + ((h & 2) == 0 ? v : -v);
}

// --- Main Noise Function ---

// 3D Perlin Noise function
float mcn_noise(float3 pos) {
    // 1. Find the unit cube that contains the point
    float3 floor_pos = floor(pos);
    int X = (int)floor_pos.x & 255;
    int Y = (int)floor_pos.y & 255;
    int Z = (int)floor_pos.z & 255;

    // 2. Find relative X,Y,Z of point in cube
    pos -= floor_pos;

    // 3. Compute fade curves for each of X,Y,Z
    float u = mcn_fade(pos.x);
    float v = mcn_fade(pos.y);
    float w = mcn_fade(pos.z);

    // 4. Hash coordinates of the 8 cube corners
    int A = p[X] + Y;
    int AA = p[A] + Z;
    int AB = p[A + 1] + Z;
    int B = p[X + 1] + Y;
    int BA = p[B] + Z;
    int BB = p[B + 1] + Z;

    // 5. Add blended results from 8 corners of the cube
    float res = mcn_lerp(w, mcn_lerp(v, mcn_lerp(u, dot(mcn_grad(p[AA], pos), pos),
                                                     dot(mcn_grad(p[BA], pos - float3(1, 0, 0)), pos - float3(1, 0, 0))),
                                           mcn_lerp(u, dot(mcn_grad(p[AB], pos - float3(0, 1, 0)), pos - float3(0, 1, 0)),
                                                     dot(mcn_grad(p[BB], pos - float3(1, 1, 0)), pos - float3(1, 1, 0)))),
                              mcn_lerp(v, mcn_lerp(u, dot(mcn_grad(p[AA + 1], pos - float3(0, 0, 1)), pos - float3(0, 0, 1)),
                                                     dot(mcn_grad(p[BA + 1], pos - float3(1, 0, 1)), pos - float3(1, 0, 1))),
                                           mcn_lerp(u, dot(mcn_grad(p[AB + 1], pos - float3(0, 1, 1)), pos - float3(0, 1, 1)),
                                                     dot(mcn_grad(p[BB + 1], pos - float3(1, 1, 1)), pos - float3(1, 1, 1)))));

    return res;
}

// Counterpart of McUtils.cs but for the GPU.

// Block pos to chunk pos
fixed3 mcn_block_to_chunk(
    fixed3 block_pos, // The block position to convert.
    fixed3 chunk_pos, // The chunk the block is in.
    fixed chunk_size_xz, // The size of the chunks in the X and Z directions.
    fixed chunk_size_y // The size of the chunks in the Y direction.
    )
{
    return block_pos - chunk_pos * fixed3(chunk_size_xz, chunk_size_y, chunk_size_xz);
}

// Block pos to world pos
fixed3 mcn_block_to_world(
    fixed3 block_pos, // The block position to convert.
    fixed3 chunk_pos, // The chunk the block is in.
    fixed chunk_size_xz, // The size of the chunks in the X and Z directions.
    fixed chunk_size_y // The size of the chunks in the Y direction.
    )
{
    return block_pos + chunk_pos * fixed3(chunk_size_xz, chunk_size_y, chunk_size_xz);
}

// Chunk pos to world pos
fixed3 mcn_chunk_to_world(
    fixed3 chunk_pos, // The target chunk position to convert.
    fixed chunk_size_xz, // The size of the chunks in the X and Z directions.
    fixed chunk_size_y // The size of the chunks in the Y direction.
    )
{
    return chunk_pos * fixed3(chunk_size_xz, chunk_size_y, chunk_size_xz);
}

// Reminder of chunk data structure
// Bits 0-7 = ID of block (0-255)
// Bit 8 = isSolid
// Bits 9-10 = visibility (opaque, transparent, or cutout. Fourth value is unused)
// Bits 11-15 = unused


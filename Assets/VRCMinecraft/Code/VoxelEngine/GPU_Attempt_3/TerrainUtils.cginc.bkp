// Minecraft Beta 1.7.3 Style Perlin Noise Implementation for Unity
// This file replicates the behavior of NoiseGeneratorPerlin.java
//
// How to Use:
// 1. Save this file as "MinecraftB173Noise.cginc" in your Unity project's Assets folder.
// 2. In your shader, include it with: #include "Assets/MinecraftB173Noise.cginc"
// 3. Call the noise function in your fragment or vertex shader:
//    float noiseValue = mcn_noise(float3(pos.x * frequency, pos.y * frequency, pos.z * frequency));
//
// Note: The permutation array `p` is hardcoded here. In the original Java code, it's
// initialized using a seeded java.util.Random instance. To get different worlds,
// you would need to regenerate and replace this array using a new seed. This
// implementation uses the default permutation array generated with a seed of 0.

#ifndef MC_B173_NOISE_INCLUDED
#define MC_B173_NOISE_INCLUDED

// --- Data Structures ---

// The permutation array, duplicated to avoid overflow.
// This is generated from new Random(0L) in Java.
